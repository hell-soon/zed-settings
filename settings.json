{
  // --- Общие настройки и UI ---
  "vim_mode": true,
  "ui_font_size": 16,
  "ui_font_family": "Maple Mono",
  "theme": {
    "mode": "system",
    "light": "Zedokai Light",
    "dark": "Zedokai Darker"
  },
  "icon_theme": "Material Icon Theme",
  "base_keymap": "VSCode",
  "minimap": {
    "show": "always"
  },

  "project_panel": {
    "dock": "left",
    "indent_size": 10
  },
  "relative_line_numbers": "enabled",
  // --- Настройки редактора (Buffer) ---
  "buffer_font_family": "Maple Mono",
  "buffer_font_size": 16,
  "buffer_font_features": {
    "calt": true,
    "liga": true,
  },
  "tab_size": 2,

  // --- Strict Typing ---
  "auto_signature_help": true,
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true
  },

    // --- Форматирование и Линтинг ---
  "format_on_save": "on",
  "formatter": "none",
  "code_actions_on_format": {
    "source.fixAll.eslint": true,
  },

  "autosave": "on_focus_change",
  "ensure_final_newline_on_save": true,
  "scrollbar": {
    "show": "always",
  },
  "indent_guides": {
    "enabled": true,
  },
  // "bracket_pair_colorization": {
  //   "enabled": true,
  // },

  // --- Языки (Только то, что требует переопределения) ---
  "languages": {
    "JavaScript": {
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "TypeScript": {
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "TSX": {
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "Vue.js": {
      "format_on_save": "on",
    },
    "Markdown": {
      // Для Markdown в Zed встроенный форматер
    },
  },

  // // --- Интеграции ---
  "lsp": {
    "wakatime": {
      "initialization_options": {
        "api-key": "API-key",
      },
    },
  },

  // --- Терминал ---
   "terminal": {
     "font_size": 15.0,
     "font_family": "MesloLGS NF",
     "font_fallbacks": ["Maple Mono"],
     "cursor_shape": "bar",
     "blinking": "on"
   },

   // --- Performance: Исключение тяжелых папок Nuxt ---
   "file_scan_exclusions":[
     "**/.git",
     "**/.nuxt",
     "**/.output",
     "**/node_modules",
     "**/dist",
     "**/*.lock"
   ]
}
